# 数据库配置（Zeabur会提供）
DATABASE_URL=postgres://用户名:密码@主机:端口/数据库名

# JWT密钥（请修改为随机字符串）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# 服务器配置
PORT=3000
NODE_ENV=production
UPLOAD_DIR=uploads

# 老师账号密码（请修改默认密码）
TEACHER_PASSWORD=admin123

# 前端URL（用于CORS配置）
FRONTEND_URL=https://your-frontend-url.zeabur.app
